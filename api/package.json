{
  "name": "@canp/api",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/api.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "dev:all": "tsx watch dev.ts",
    "debug:powerstock": "tsx src/dev/powerStockDebug.ts",
    "build": "tsc -p tsconfig.json",
    "start:api": "node dist/api.js",
    "start:worker": "node dist/worker.js",
    "start:all": "node dist/start.js",
    "migrate": "tsx src/migrate.ts",
    "seed": "tsx src/seed.ts",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.0.2",
    "bcryptjs": "^3.0.2",
    "cheerio": "^1.1.2",
    "dotenv": "^16.5.0",
    "fastify": "^5.3.3",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.16.0",
    "pg-boss": "^10.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.15.0",
    "@types/pg": "^8.20.0",
    "eslint": "^9.27.0",
    "playwright": "^1.59.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.0",
    "vitest": "^3.2.4"
  }
}
